{
  "name": "drax-back",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "scripts": {
    "back": "nodemon --exec node --env-file .env --loader ts-node/esm src/index.ts",
    "prod": "node --env-file .env  index.js",
    "build": "tsc -p tsconfig.json && copyfiles package.json ../out",
    "build:local": "tsc -p tsconfig.build.json && copyfiles package.json ../build",
    "copyPackage": "copyfiles package.json ../out",
    "copyPackage:local": "copyfiles package.json ../build",
    "copygql": "copyfiles -u 1 ./**/*.graphql out/",
    "copygql:local": "copyfiles -u 1 ./**/*.graphql build/",
    "tsc": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/**/*.test* ",
    "recoveryAdmin": " node --env-file .env --loader ts-node/esm src/setup/scripts/RecoverAdminPassword.ts",
    "initRootUserAndAdminRole": " node --env-file .env --loader ts-node/esm src/setup/scripts/CreateRootUserAndAdminRole.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@drax/common-back": "^3.18.0",
    "@drax/crud-back": "^3.20.0",
    "@drax/identity-back": "^3.20.0",
    "@drax/media-back": "^3.20.0",
    "@drax/settings-back": "^3.20.0",
    "@drax/dashboard-back": "^3.20.0",
    "@drax/audit-back": "^3.20.0",
    "@drax/ai-back": "^3.20.0",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.5",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "graphql": "^16.6.0",
    "graphql-yoga": "^5.3.1",
    "mongoose": "^8.23.0",
    "mongoose-paginate-v2": "^1.8.5",
    "mongoose-unique-validator": "^5.0.0",
    "google-auth-library": "^9.15.0",
    "mongodb": "^6.15.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.2",
    "@types/node": "^20.2.1",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "tsx": "^4.19.1",
    "vitest": "^3.2.4",
    "mongodb-memory-server": "^11.0.1"
  }
}
